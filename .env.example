# Crew configuration — one file for compose and local source runs.
#
# Copy to .env and fill in. Do not quote values — python-dotenv treats quotes
# as literal characters. Shell environment variables take precedence over
# this file. Compose overrides in-container values (database hosts,
# CREW_HOST_URL, credential paths) per service.

# --- Required: hosted runtime ---
# Crew application data and Mash runtime data use separate logical databases.
CREW_DATABASE_URL=postgresql://crew_api:crew_api@127.0.0.1:5434/crew_app
MASH_DATABASE_URL=postgresql://mash_host:mash_host@127.0.0.1:5434/mash_runtime
CREW_HOST_URL=http://127.0.0.1:8004
MASH_API_KEY=replace_me_for_local_service

# --- Optional: DBOS Conductor (cloud observability for the durable runtime) ---
# The runtime self-hosts against Postgres and starts fine without this. Set it
# only to connect the durable workflow engine to DBOS Conductor.
# DBOS_CONDUCTOR_KEY=

# --- Required: data + pm agents ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Optional: BigQuery (data agent tools + crew-api metric visualizations) ---
# Without these the data agent still registers (its BigQuery MCP tools stay
# off) and Metrics Explorer visualizations are unavailable. Point
# GOOGLE_APPLICATION_CREDENTIALS at the service-account JSON on this machine;
# compose mounts that file into crew-host and crew-api automatically.
# BIGQUERY_PROJECT_ID=
# BIGQUERY_MCP_URL=https://bigquery.googleapis.com/mcp
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GOOGLE_CLOUD_PROJECT=

# --- crew-api / web UI + authenticated CLI ---
# Required to log in (the CLI and web UI authenticate as these users).
CREW_BETA_ALLOWED_USERS=alice,bob
CREW_BETA_AUTH_SECRET=replace_me_for_local_beta
# CREW_BETA_TOKEN_TTL_SECONDS=604800
# CREW_BETA_CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
