# Crew host runtime configuration.
#
# Copy to .env and fill in. Do not quote values — python-dotenv treats quotes
# as literal characters. Shell environment variables take precedence over this
# file; per-agent files under src/crew/agents/<id>/.env override the project
# .env for local source runs.

# --- Required: hosted runtime ---
# The shared Postgres database used by the runtime and all persisted state.
# Forwarded to the Mash runtime as MASH_DATABASE_URL at startup.
# Local dev loop (docker compose up -d db): use the line below.
CREW_DATABASE_URL=postgresql://mash:mash@127.0.0.1:5434/mash_crew
# DBOS conductor key — required whenever the hosted Mash runtime starts.
DBOS_CONDUCTOR_KEY=

# --- Required: data + pm agents ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Optional: BigQuery for the data agent ---
# Without these the data agent still registers; its BigQuery MCP tools stay off.
# In a container, mount the service-account JSON and point ADC at it.
# BIGQUERY_PROJECT_ID=
# BIGQUERY_MCP_URL=https://bigquery.googleapis.com/mcp
# GOOGLE_APPLICATION_CREDENTIALS=/secrets/service-account.json
# GOOGLE_CLOUD_PROJECT=

# --- Optional: protect the host API with a bearer key ---
# MASH_API_KEY=

# --- BFF / web UI + authenticated CLI (CREW_SERVE_MODE=beta) ---
# Required to log in (the CLI and web UI authenticate as these users).
CREW_BETA_ALLOWED_USERS=alice,bob
CREW_BETA_AUTH_SECRET=replace_me_for_local_beta
# CREW_BETA_TOKEN_TTL_SECONDS=604800
# CREW_BETA_CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
